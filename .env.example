# ── Core (bot worker) ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_role_or_anon_key
PORT=3000

# ── Voice-call reminders (Care+) ──
# All voice endpoints/scheduler stay inert until VOICE_CALLS_ENABLED=true AND the
# provider creds below are present. Set the SAME values on BOTH hosts:
#   • Vercel (web)   → webhooks + OTP
#   • Render (worker)→ scheduler + outbound calls
# See docs/VOICE_LAUNCH_CHECKLIST.md.
VOICE_CALLS_ENABLED=false
# Public origin the telephony provider can reach for IVR/status webhooks (the web app).
PUBLIC_WEBHOOK_BASE_URL=https://your-app.vercel.app

# Exotel (outbound voice). EXOTEL_SID/EXOTEL_ACCOUNT_SID are accepted interchangeably.
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_PHONE_NUMBER=            # verified ExoPhone / caller ID
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_FLOW_URL=               # Exotel Flow Builder app URL: http://my.exotel.com/<sid>/exoml/start_voice/<app_id>

# Cost caps for the paid voice feature.
VOICE_DAILY_CALL_CAP=6
VOICE_MONTHLY_CALL_QUOTA=90

# ── SMS OTP (phone verification) ──
# India: requires a DLT-registered template. Choose one provider.
SMS_PROVIDER=msg91             # 'msg91' | 'exotel'
# MSG91
MSG91_AUTHKEY=
MSG91_SENDER=
MSG91_TEMPLATE_ID=             # DLT-approved OTP template id
# Exotel SMS (if SMS_PROVIDER=exotel; reuses the EXOTEL_* creds above)
EXOTEL_SMS_SENDER=

# ── Billing (Razorpay — only if charging for Care+) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CAREPLUS_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=
